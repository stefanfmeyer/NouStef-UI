{
  "name": "@noustef-ui/hermes-recipes",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "concurrently -k -n bridge,web -c cyan,magenta \"pnpm --filter @noustef-ui/bridge dev\" \"pnpm --filter @noustef-ui/web dev\"",
    "start": "pnpm --filter @noustef-ui/bridge start -- --static-dir ../web/dist",
    "kitchen": "node scripts/kitchen.mjs",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "turbo run typecheck",
    "test": "NODE_OPTIONS=--experimental-sqlite vitest run --config vitest.unit.config.ts",
    "test:live:home": "pnpm --filter @noustef-ui/bridge test:live:home",
    "security": "node scripts/security-check.mjs",
    "ci:full": "pnpm lint && pnpm typecheck && pnpm test && pnpm security"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "uuid": ">=14.0.0"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.3",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
