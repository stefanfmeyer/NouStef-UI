    "test:live:home": "tsx scripts/live-home-workspace-validation.ts"
  },
  "dependencies": {
    "@hermes-recipes/protocol": "workspace:*",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}
