{
  "name": "@noustef-ui/bridge",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--experimental-sqlite tsx src/server.ts --port 8787",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "NODE_OPTIONS=--experimental-sqlite tsx src/server.ts --host 0.0.0.0",
    "start:fixture": "NODE_OPTIONS=--experimental-sqlite tsx src/server.ts --fixture",
    "test:live:home": "tsx scripts/live-home-workspace-validation.ts"
  },
  "dependencies": {
    "@noustef-ui/protocol": "workspace:*",
    "busboy": "^1.6.0",
    "exceljs": "^4.4.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "tsx": "^4.19.3"
  }
}
