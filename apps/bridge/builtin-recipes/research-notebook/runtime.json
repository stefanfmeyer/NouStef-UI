{
  "id": "research-notebook",
  "name": "Research Notebook",
  "useCase": "Gather sources, notes, extracted points, and follow-up prompts.",
  "enabled": true,
  "selectionSignals": [
    "research notebook",
    "sources and notes",
    "claims",
    "follow-up questions",
    "research topic",
    "why is",
    "explain",
    "how does",
    "dig into",
    "learn about",
    "deep dive on"
  ],
  "slots": [
    { "id": "research-tabs", "kind": "tabs", "required": true }
  ],
  "allowedUpdateOps": ["set_header", "set_active_tab", "upsert_groups", "append_note_lines", "remove_items"],
  "actions": {
    "run-followup": {
      "id": "run-followup",
      "label": "Run follow-up",
      "kind": "bridge",
      "intent": "primary",
      "visibility": { "requiresSelection": "single", "whenBuildReady": true },
      "bridge": { "handler": "run_template_followup", "payload": {} },
      "prompt": {
        "promptTemplate": "Follow up on the selected research item: expand notes, find additional sources, or answer open questions.",
        "includeInputs": ["selected_items", "original_prompt"],
        "allowedMutations": ["raw_data", "normalized_data"],
        "outboundRequestsAllowed": true,
        "expectedOutput": "recipe_data_update",
        "timeoutMs": 120000,
        "retryable": true
      },
      "metadata": {}
    },
    "append-template-note": {
      "id": "append-template-note",
      "label": "Add note",
      "kind": "bridge",
      "intent": "neutral",
      "visibility": { "requiresSelection": "none", "whenBuildReady": true },
      "bridge": { "handler": "append_template_note", "payload": {} },
      "metadata": {}
    }
  },
  "transitions": []
}
