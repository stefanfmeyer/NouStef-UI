{
  "id": "restaurant-finder",
  "name": "Restaurant Finder",
  "useCase": "Find and compare nearby restaurants with fast booking-oriented context.",
  "enabled": true,
  "selectionSignals": [
    "restaurants nearby",
    "dinner options",
    "places to eat",
    "restaurant shortlist",
    "where to eat",
    "good restaurants in",
    "dinner tonight",
    "somewhere for dinner",
    "lunch spots near me",
    "best restaurants for",
    "make a reservation"
  ],
  "slots": [
    { "id": "filters", "kind": "filter-strip", "required": true },
    { "id": "results", "kind": "split", "required": true }
  ],
  "allowedUpdateOps": ["set_header", "set_filter_chips", "upsert_groups", "set_detail", "append_note_lines"],
  "actions": {
    "append-template-note": {
      "id": "append-template-note",
      "label": "Add note",
      "kind": "bridge",
      "intent": "neutral",
      "visibility": { "requiresSelection": "none", "whenBuildReady": true },
      "bridge": { "handler": "append_template_note", "payload": {} },
      "metadata": {}
    }
  },
  "transitions": []
}
